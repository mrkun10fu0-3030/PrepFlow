<%= form_with(model: prep_task) do |form| %>
  <% if prep_task.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% prep_task.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  
  <div class="mb-3">
    <%= form.label :priority, "優先度", class: "form-label" %>
    <%= form.select :priority, [["低", "low"], ["中", "medium"], ["高", "high"]], {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= form.label :prep_date, "日付", class: "form-label" %>
    <%= form.date_field :prep_date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :title, "仕込み名", class: "form-label" %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :target_qty, "指示量", class: "form-label" %>
    <%= form.text_field :target_qty, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :comment, "コメント", class: "form-label" %>
    <%= form.textarea :comment, class: "form-control", rows: 3 %>
  </div>

  <div class="mb-3 form-check">
    <%= form.checkbox :completed, class: "form-check-input" %>
    <%= form.label :completed, "完了", class: "form-check-label" %>
  </div>

  <%= form.submit "登録", class: "btn btn-success w-100" %>
<% end %>