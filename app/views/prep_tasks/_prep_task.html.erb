<div id="<%= dom_id prep_task %>" class="<%= prep_task.completed ? 'opacity-50' : '' %>">
  <table class="table table-borderless mb-0">
    <tbody>
      <tr>
        <th class="text-muted">優先度</th>
        <td>
          <% if prep_task.high? %>
            <span class="badge bg-danger">高</span>
          <% elsif prep_task.medium? %>
            <span class="badge bg-warning">中</span>
          <% else %>
            <span class="badge bg-secondary">低</span>
          <% end %>
        </td>
      </tr>
      <tr>
        <th class="text-muted" style="width: 30%">日付</th>
        <td><%= prep_task.prep_date %></td>
      </tr>
      <tr>
        <th class="text-muted">仕込み名</th>
        <td><%= prep_task.title %></td>
      </tr>
      <tr>
        <th class="text-muted">指示量</th>
        <td><%= prep_task.target_qty %></td>
      </tr>
      <tr>
        <th class="text-muted">実績量</th>
        <td><%= prep_task.actual_qty %></td>
      </tr>
      <tr>
        <th class="text-muted">コメント</th>
        <td><%= prep_task.comment %></td>
      </tr>
      <tr>
        <th class="text-muted">実施</th>
        <td>
          <% if prep_task.completed %>
            <span class="badge bg-success">済</span>
          <% else %>
            <span class="badge bg-secondary">未</span>
          <% end %>
        </td>
      </tr>
      <tr>
        <th class="text-muted">担当者</th>
        <td><%= prep_task.staff.username if prep_task.staff %></td>
      </tr>
    </tbody>
  </table>

  <% if current_user.staff? && !prep_task.completed %>
    <%= form_with url: complete_prep_task_path(prep_task), method: :patch do |f| %>
      <div class="mb-2">
        <%= f.label :actual_qty, "実績量", class: "form-label" %>
        <%= f.text_field :actual_qty, class: "form-control form-control-sm" %>
      </div>
      <div class="mb-2">
        <%= f.label :comment, "コメント", class: "form-label" %>
        <%= f.text_area :comment, class: "form-control form-control-sm", rows: 2 %>
      </div>
      <%= f.submit "完了報告", class: "btn btn-success btn-sm w-100" %>
    <% end %>
  <% end %>
</div>
