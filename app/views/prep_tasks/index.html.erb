<div class="container mt-4">
  <p class="text-success"><%= notice %></p>

  <% content_for :title, "仕込み一覧" %>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="fw-bold" style="color: #2d6a4f;">仕込みリスト</h1>
    <% if current_user.manager? %>
      <%= link_to "仕込み登録", new_prep_task_path, class: "btn btn-success" %>
    <% end %>
  </div>

  <%= form_with url: prep_tasks_path, method: :get, class: "d-flex gap-2 mb-4" do |f| %>
    <%= f.date_field :prep_date, class: "form-control w-auto" %>
    <%= f.submit "検索", class: "btn btn-outline-success" %>
  <% end %>

  <div class="row" id="prep_tasks">
    <% @prep_tasks.each do |prep_task| %>
      <div class="col-md-4 mb-3">
        <div class="card shadow-sm">
          <div class="card-body">
            <%= render prep_task %>
            <%= link_to "詳細を見る", prep_task, class: "btn btn-sm btn-outline-success mt-2" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>