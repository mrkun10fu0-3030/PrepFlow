<h2>プロフィール編集</h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <p><%= f.label :username, "ユーザー名" %></p>
    <p><%= f.text_field :username %></p>
  </div>

  <div class="field">
    <p><%= f.label :avatar, "アイコン画像" %></p>
    <p><%= f.file_field :avatar %></p>
  </div>

  <div class="actions">
    <%= f.submit "更新" %>
  </div>
<% end %>
<div><%= button_to "アカウント削除", registration_path(resource_name), data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete %></div>

<%= link_to "戻る", :back %>
